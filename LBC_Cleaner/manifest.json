{
  "manifest_version": 3,
  "name": "LBC Cleaner",
  "version": "1.2",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gérer les filtres LBC"
  },
  "content_scripts": [
    {
      "matches": ["https://www.leboncoin.fr/*"],
      "js": ["content.js"]
    }
  ]
}